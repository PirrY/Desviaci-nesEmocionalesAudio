   "source": [
    "def plot_before_after_spectrogram(y_before, y_after, sr, title_b, title_a):\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(18, 9))\n",
    "\n",
    "    for row_axes, (y_v, lbl) in zip(axes, [(y_before, title_b), (y_after, title_a)]):\n",
    "        t   = np.linspace(0, len(y_v) / sr, len(y_v))\n",
    "        # Forma de onda\n",
    "        row_axes[0].plot(t, y_v, color='steelblue', linewidth=0.3)\n",
    "        row_axes[0].set_title(f'Forma de onda — {lbl}')\n",
    "        row_axes[0].set_xlabel('Tiempo (s)')\n",
    "        row_axes[0].set_ylabel('Amplitud')\n",
    "\n",
    "        # Espectrograma\n",
    "        S  = librosa.amplitude_to_db(np.abs(librosa.stft(y_v)), ref=np.max)\n",
    "        librosa.display.specshow(S, sr=sr, x_axis='time', y_axis='hz',\n",
    "                                  ax=row_axes[1], cmap='magma')\n",
    "        row_axes[1].set_ylim(0, 4000)\n",
    "        row_axes[1].set_title(f'Espectrograma — {lbl}')\n",
    "\n",
    "    plt.suptitle('Antes vs. Después del preprocesamiento', fontsize=13, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(OUTPUT / 'before_after.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "plot_before_after_spectrogram(y_raw, y_norm, SR, 'Crudo', 'Procesado')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Impacto en los features de análisis\n",
    "\n",
    "Calculamos el pitch y el HNR en el audio crudo vs. procesado para mostrar\n",
    "la mejora concreta en las estimaciones."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compare_key_features(y_raw, y_clean, sr):\n",
    "    results = {}\n",
    "    for label, y in [('Crudo', y_raw), ('Procesado', y_clean)]:\n",
    "        # Pitch\n",
    "        f0, voiced, _ = librosa.pyin(y, fmin=75, fmax=500, sr=sr)\n",
    "        vf0 = f0[voiced]\n",
    "\n",
    "        # HNR (Praat)\n",
    "        try:\n",
    "            import parselmouth\n",
    "            from parselmouth.praat import call\n",
    "            snd  = parselmouth.Sound(y.astype(np.float64), sampling_frequency=sr)\n",
    "            harm = call(snd, 'To Harmonicity (cc)', 0.01, 75, 0.1, 1.0)\n",
    "            hnr  = call(harm, 'Get mean', 0, 0)\n",
    "        except Exception:\n",
    "            hnr = np.nan\n",
    "\n",
    "        results[label] = {\n",
    "            'pitch_mean_hz':   round(np.nanmean(vf0), 2)  if len(vf0) > 0 else np.nan,\n",
    "            'pitch_std_hz':    round(np.nanstd(vf0), 2)   if len(vf0) > 0 else np.nan,\n",
    "            'voiced_ratio':    round(voiced.mean(), 3),\n",
    "            'hnr_db':          round(float(hnr), 2)        if np.isfinite(hnr) else np.nan,\n",
    "        }\n",
    "\n",
    "    df_cmp = pd.DataFrame(results).T\n",
    "    print('\\n── Impacto en features ──────────────────────────')\n",
    "    display(df_cmp)\n",
    "\n",
    "    # Plot: pitch antes/después\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(16, 4))\n",
    "    for ax, (y_v, lbl) in zip(axes, [(y_raw, 'Crudo'), (y_norm, 'Procesado')]):\n",
    "        f0, voiced, _ = librosa.pyin(y_v, fmin=75, fmax=500, sr=sr)\n",
    "        t_f0 = librosa.times_like(f0, sr=sr)\n",
    "        ax.plot(t_f0, f0, color='navy', linewidth=1.2, alpha=0.9)\n",
    "        ax.fill_between(t_f0, f0, where=voiced, color='navy', alpha=0.2)\n",
    "        ax.axhline(np.nanmean(f0[voiced]), color='red', linestyle='--',\n",
    "                   linewidth=1.5, label=f'Media: {np.nanmean(f0[voiced]):.1f} Hz')\n",
    "        ax.set_title(f'Pitch F0 — {lbl}')\n",
    "        ax.set_xlabel('Tiempo (s)')\n",
    "        ax.set_ylabel('Hz')\n",
    "        ax.legend(fontsize=9)\n",
    "\n",
    "    plt.suptitle('Pitch antes vs. después del preprocesamiento', fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(OUTPUT / 'pitch_comparison.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "    return df_cmp\n",
    "\n",
    "\n",
    "df_feature_comparison = compare_key_features(y_raw, y_norm, SR)"
   ]
  },
